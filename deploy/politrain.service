# systemd USER unit (no root needed; Linger=yes is enabled for politrain).
# Install: cp deploy/politrain*.{service,timer} ~/.config/systemd/user/ &&
#          systemctl --user daemon-reload && systemctl --user enable --now politrain
[Unit]
Description=Politrain FastAPI backend (uvicorn)
After=network.target

[Service]
WorkingDirectory=/home/politrain/politrain_code/backend
EnvironmentFile=/home/politrain/politrain_code/.env
ExecStart=/home/politrain/politrain_code/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
# keep the familiar log location used throughout CLAUDE.md debugging
StandardOutput=append:/tmp/uvicorn.log
StandardError=append:/tmp/uvicorn.log

[Install]
WantedBy=default.target
